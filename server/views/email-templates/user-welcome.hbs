<!doctype html>
<html lang="{{language}}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="x-apple-disable-message-reformatting">
    <title>{{subject}}</title>
  </head>
  <body style="margin:0; padding:0; background:#0f0f12; color:#ffffff;">
    <div style="display:none; max-height:0; overflow:hidden; opacity:0;">{{preheader}}</div>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#0f0f12;">
      <tr>
        <td align="center" style="padding:24px 16px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:600px; background:#18181b; border:1px solid #2f2f35; border-radius:12px;">
            <tr>
              <td style="padding:28px 32px 18px; border-bottom:1px solid #2f2f35;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="padding-right:12px;">
                      <img src="{{logo_url}}" width="38" height="38" alt="Blachere Boards" style="display:block; border-radius:8px;">
                    </td>
                    <td style="font:700 22px/1.2 -apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif; color:#ffffff;">Blachere Boards</td>
                  </tr>
                </table>
              </td>
            </tr>
            <tr>
              <td style="padding:30px 32px 10px; font:700 25px/1.3 -apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif; color:#ffffff;">{{greeting}}</td>
            </tr>
            <tr>
              <td style="padding:0 32px 24px; font:400 15px/1.65 -apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif; color:#d4d4d8;">{{introduction}}</td>
            </tr>
            <tr>
              <td style="padding:0 32px 24px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#111114; border:1px solid #34343a; border-radius:10px;">
                  <tr>
                    <td style="padding:20px 22px 8px; font:600 12px/1.4 -apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif; color:#a1a1aa; text-transform:uppercase; letter-spacing:.04em;">{{login_email_label}}</td>
                  </tr>
                  <tr>
                    <td style="padding:0 22px 18px; font:600 16px/1.4 -apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif; color:#ffffff;">{{email}}</td>
                  </tr>
                  <tr>
                    <td style="padding:0 22px 8px; font:600 12px/1.4 -apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif; color:#a1a1aa; text-transform:uppercase; letter-spacing:.04em;">{{temporary_password_label}}</td>
                  </tr>
                  <tr>
                    <td style="padding:0 22px 20px; font:700 19px/1.4 ui-monospace,SFMono-Regular,Consolas,monospace; color:#ffffff; letter-spacing:.04em;">{{temporary_password}}</td>
                  </tr>
                </table>
              </td>
            </tr>
            <tr>
              <td align="center" style="padding:0 32px 24px;">
                <a href="{{login_url}}" target="_blank" style="display:inline-block; padding:13px 24px; border-radius:8px; background:#22c55e; color:#07150b; font:700 15px/1 -apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif; text-decoration:none;">{{open_boards_label}}</a>
              </td>
            </tr>
            <tr>
              <td style="padding:0 32px 30px; font:400 13px/1.55 -apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif; color:#a1a1aa;">{{security_notice}}</td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
